# Server Configuration
PORT=5001

# Database Configuration
# Use PostgreSQL (e.g., Neon, Vercel Postgres)
# Get your connection string from your database provider
POSTGRES_URL=postgresql://user:password@host:port/database?sslmode=require

# Alternative: If using DATABASE_URL instead of POSTGRES_URL
# DATABASE_URL=postgresql://user:password@host:port/database?sslmode=require

# Authentication
# Generate a strong random secret for JWT signing
# You can use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-here-use-strong-random-value

# Node Environment
NODE_ENV=development

# Frontend Configuration
VITE_API_URL=http://localhost:5001/api
