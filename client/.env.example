# === DSA Tracker Frontend - Environment Variables ===
# Copy this file to .env and fill in your values for local development.
# Set these as Vercel Environment Variables for the FRONTEND project.

# ── Backend API URL ───────────────────────────────────────────────────────────
# For local development, leave commented out (defaults to http://localhost:5001/api)
# For production, set to your Vercel backend URL:
VITE_API_URL=https://your-backend-project.vercel.app/api
