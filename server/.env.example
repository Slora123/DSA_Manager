# === DSA Tracker Backend - Environment Variables ===
# Copy this file to .env and fill in your values for local development.
# Set these as Vercel Environment Variables for the BACKEND project.

# ── PostgreSQL (Neon) ─────────────────────────────────────────────────────────
# Get this from your Neon project dashboard → Connection String
POSTGRES_URL=postgresql://user:password@host/dbname?sslmode=require

# ── Authentication ────────────────────────────────────────────────────────────
# Generate a strong random secret:  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-jwt-secret-here

# ── CORS ──────────────────────────────────────────────────────────────────────
# Set this to your frontend's Vercel URL (no trailing slash)
# Leave unset (or '*') for local development
CORS_ORIGIN=https://your-frontend-project.vercel.app

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5001
